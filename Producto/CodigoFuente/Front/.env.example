VITE_API_BASE_URL=http://localhost:8000
VITE_ENABLE_MOCK_DATA=false
VITE_HTTPS=false
VITE_SSL_CERTFILE=../certs/dev/bluegridocr.local.pem
VITE_SSL_KEYFILE=../certs/dev/bluegridocr.local.key

# Docker/Azure runtime. If set in the container, this overrides VITE_API_BASE_URL.
# Use an empty value with nginx.azure.conf to call the API through the same origin (/api).
API_BASE_URL=http://localhost:8000
